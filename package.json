{
  "name": "carpenter",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "bun test",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:reset": "prisma migrate reset --force && bun run db:seed",
    "db:seed": "bun run prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.2.1",
    "commander": "^15.0.0",
    "next": "^15.1.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.4",
    "@types/react-dom": "^19.0.2",
    "bun-types": "^1.1.43",
    "prisma": "^6.2.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.3"
  }
}
